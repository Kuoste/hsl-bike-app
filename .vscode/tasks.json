{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "run HslBikeApp",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "src/HslBikeApp"
      ],
      "isBackground": true,
      "runOptions": {
        "instanceLimit": 1
      },
      "problemMatcher": {
        "owner": "csharp",
        "pattern": {
          "regexp": "^\\s*(.+)\\((\\d+),(\\d+)\\):\\s+(error|warning)\\s+(.+?):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*dotnet run.*|.*Building.*",
          "endsPattern": ".*Now listening on.*|.*Content root path.*|.*Application started.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "watch HslBikeApp",
      "type": "process",
      "command": "dotnet",
      "args": [
        "watch",
        "--project",
        "src/HslBikeApp",
        "run"
      ],
      "isBackground": true,
      "runOptions": {
        "instanceLimit": 1
      },
      "problemMatcher": {
        "owner": "csharp",
        "pattern": {
          "regexp": "^\\s*(.+)\\((\\d+),(\\d+)\\):\\s+(error|warning)\\s+(.+?):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*dotnet watch.*|.*Building.*",
          "endsPattern": ".*Now listening on.*|.*Content root path.*|.*Application started.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}